plot(ts_level, "ATR Trailing Stop", color=ts_color, linewidth=2, style=plot.style_line)

p_bb_hi = plot(show_bb ? bb_upper : na, "BB Upper", color=color.new(#9C27B0, 55), linewidth=1)
p_bb_lo = plot(show_bb ? bb_lower : na, "BB Lower", color=color.new(#9C27B0, 55), linewidth=1)
fill(p_bb_hi, p_bb_lo, color=color.new(#9C27B0, 88))

p_kc_hi = plot(show_kc ? kc_upper : na, "KC Upper", color=color.new(#2962FF, 55), linewidth=1)
p_kc_lo = plot(show_kc ? kc_lower : na, "KC Lower", color=color.new(#2962FF, 55), linewidth=1)
fill(p_kc_hi, p_kc_lo, color=color.new(#2962FF, 92))

plot(show_trend_emas ? ema_fast : na, "EMA Fast", color=color.new(#FFA726, 45), linewidth=1)
plot(show_trend_emas ? ema_slow : na, "EMA Slow", color=color.new(#26A69A, 45), linewidth=1)

sq_dot_col = in_squeeze ? color.new(#FF9800, 0) : squeeze_released ? color.new(#00C853, 0) : release_window_ok ? color.new(#FDD835, 0) : color.new(#9E9E9E, 80)
plotshape(true, "Squeeze Dots", shape.circle, location.bottom, color=sq_dot_col, size=size.tiny)

plotshape(long_entry_confirmed and show_labels, "Long Entry", shape.triangleup, location.belowbar, color=grade_color(long_grade), size=size.normal, text="BUY", textcolor=grade_text_color(long_grade))
plotshape(long_entry_confirmed and not show_labels, "Long Entry (Silent)", shape.triangleup, location.belowbar, color=grade_color(long_grade), size=size.normal)
plotshape(short_entry_confirmed and show_labels, "Short Entry", shape.triangledown, location.abovebar, color=grade_color(short_grade), size=size.normal, text="SELL", textcolor=grade_text_color(short_grade))
plotshape(short_entry_confirmed and not show_labels, "Short Entry (Silent)", shape.triangledown, location.abovebar, color=grade_color(short_grade), size=size.normal)

plotshape(long_setup and not ts_flipped_long, "Long Setup", shape.diamond, location.belowbar, color=color.new(#00C853, 70), size=size.tiny)
plotshape(short_setup and not ts_flipped_short, "Short Setup", shape.diamond, location.abovebar, color=color.new(#F44336, 70), size=size.tiny)

plotshape(long_trigger_blocked, "Long Trigger Blocked", shape.xcross, location.abovebar, color=color.new(#E53935, 0), size=size.small, text="BLOCK")
plotshape(short_trigger_blocked, "Short Trigger Blocked", shape.xcross, location.belowbar, color=color.new(#E53935, 0), size=size.small, text="BLOCK")

plotshape(long_exit and not long_entry_confirmed, "Long Exit", shape.xcross, location.abovebar, color=color.new(#2962FF, 20), size=size.small)
plotshape(short_exit and not short_entry_confirmed, "Short Exit", shape.xcross, location.belowbar, color=color.new(#E91E8C, 20), size=size.small)

// ══════════════════════════════════════════════════════════════════════════════
//  STATUS TABLE
// ══════════════════════════════════════════════════════════════════════════════
C_HDR = color.new(#263238, 0)
C_TXT = color.white
C_OFF = color.new(#455A64, 50)

var table status = table.new(position.bottom_right, 2, 10,
     bgcolor=color.new(#263238, 10), border_color=color.new(#546E7A, 40), border_width=1,
     frame_color=color.new(#546E7A, 40), frame_width=1)

if barstate.islast and show_table
    table.cell(status, 0, 0, "0DTE EXECUTION", bgcolor=C_HDR, text_color=C_TXT, text_size=size.small)
    table.cell(status, 1, 0, bias_state == "BULL" ? "LONG" : bias_state == "BEAR" ? "SHORT" : "WAIT", bgcolor=state_color(bias_state), text_color=C_TXT, text_size=size.small)

    tick_bg = tick_state == "STRONG BULL" ? color.new(#00C853, 35) : tick_state == "STRONG BEAR" ? color.new(#F44336, 35) : C_OFF
    tick_str = na(tick_val) ? "N/A" : tick_state + " (" + str.tostring(math.round(tick_val)) + ")"
    table.cell(status, 0, 1, "TICK", bgcolor=C_HDR, text_color=C_TXT, text_size=size.small)
    table.cell(status, 1, 1, tick_str, bgcolor=tick_bg, text_color=C_TXT, text_size=size.small)

    table.cell(status, 0, 2, "OR", bgcolor=C_HDR, text_color=C_TXT, text_size=size.small)
    or_bg = or_state == "ABOVE" or or_state == "ABOVE+" ? color.new(#00C853, 35) :
         or_state == "BELOW" or or_state == "BELOW+" ? color.new(#F44336, 35) :
         color.new(#FFB300, 35)
    table.cell(status, 1, 2, or_mode + " / " + or_state, bgcolor=or_bg, text_color=C_TXT, text_size=size.small)

    table.cell(status, 0, 3, "BIAS", bgcolor=C_HDR, text_color=C_TXT, text_size=size.small)
    table.cell(status, 1, 3, bias_state, bgcolor=state_color(bias_state), text_color=C_TXT, text_size=size.small)

    table.cell(status, 0, 4, "SETUP", bgcolor=C_HDR, text_color=C_TXT, text_size=size.small)
    table.cell(status, 1, 4, setup_state, bgcolor=state_color(setup_state), text_color=C_TXT, text_size=size.small)

    table.cell(status, 0, 5, "TRIGGER", bgcolor=C_HDR, text_color=C_TXT, text_size=size.small)
    table.cell(status, 1, 5, trigger_state, bgcolor=state_color(trigger_state), text_color=C_TXT, text_size=size.small)

    exhaustion_state = not use_exhaustion_filter ? "OFF" : bias_state == "BULL" ? (exh_long_ok ? "CLEAR" : "BLOCKED") : bias_state == "BEAR" ? (exh_short_ok ? "CLEAR" : "BLOCKED") : "WAIT"
    exhaustion_bg = not use_exhaustion_filter ? C_OFF : exhaustion_state == "CLEAR" ? color.new(#00C853, 35) : exhaustion_state == "BLOCKED" ? color.new(#E53935, 35) : C_OFF
    table.cell(status, 0, 6, "EXHAUST", bgcolor=C_HDR, text_color=C_TXT, text_size=size.small)
    table.cell(status, 1, 6, exhaustion_state + " / " + time_state, bgcolor=exhaustion_bg, text_color=C_TXT, text_size=size.small)

    table.cell(status, 0, 7, "SCORE", bgcolor=C_HDR, text_color=C_TXT, text_size=size.small)
    table.cell(status, 1, 7, str.tostring(selected_score), bgcolor=grade_color(selected_grade), text_color=grade_text_color(selected_grade), text_size=size.small)

    table.cell(status, 0, 8, "GRADE", bgcolor=C_HDR, text_color=C_TXT, text_size=size.small)
    table.cell(status, 1, 8, selected_grade, bgcolor=grade_color(selected_grade), text_color=grade_text_color(selected_grade), text_size=size.small)

    release_str = squeeze_released ? "RELEASE 0" : release_window_ok ? "REL " + str.tostring(bars_since_squeeze_release) : in_squeeze ? "IN SQ " + str.tostring(sq_count) : "STALE"
    release_bg = squeeze_released or release_window_ok ? color.new(#00C853, 35) : in_squeeze ? color.new(#FFB300, 35) : C_OFF
    table.cell(status, 0, 9, "RELEASE", bgcolor=C_HDR, text_color=C_TXT, text_size=size.small)
    table.cell(status, 1, 9, release_str, bgcolor=release_bg, text_color=C_TXT, text_size=size.small)
else if barstate.islast
    table.clear(status, 0, 0, 1, 9)

// ══════════════════════════════════════════════════════════════════════════════
//  CONVERSION TABLE — PRD Phase 1
// ══════════════════════════════════════════════════════════════════════════════
prd_state_color(s) =>
    s == "NEAR_BREAKOUT"  ? color.new(#00C853, 25) :
     s == "NEEDS_BREAKOUT" ? color.new(#FDD835, 25) :
     s == "NEEDS_PULLBACK" ? color.new(#FDD835, 25) :
     s == "COMPRESSION"   ? color.new(#546E7A, 35)  :
     color.new(#B71C1C, 35)  // BROKEN

C_CV_HDR = color.new(#1A237E, 0)
C_CV_BG  = color.new(#263238, 20)
C_CV_OFF = color.new(#263238, 80)

var table cv_table = table.new(position.top_right, 2, 5,
     bgcolor=color.new(#1A237E, 10), border_color=color.new(#3949AB, 40), border_width=1,
     frame_color=color.new(#3949AB, 40), frame_width=1)

if barstate.islast and show_conversion
    _state_bg  = prd_state_color(prd_state)
    _state_txt = (prd_state == "NEEDS_PULLBACK" or prd_state == "NEEDS_BREAKOUT") ? color.black : color.white

    table.cell(cv_table, 0, 0, "SETUP",    bgcolor=C_CV_HDR, text_color=color.white, text_size=size.small)
    table.cell(cv_table, 1, 0, prd_state + prd_proximity_tag, bgcolor=_state_bg, text_color=_state_txt, text_size=size.small)

    if prd_actionable
        table.cell(cv_table, 0, 1, "BREAK >",   bgcolor=C_CV_HDR, text_color=color.white, text_size=size.small)
        table.cell(cv_table, 1, 1, str.tostring(breakoutLevel,    format.mintick), bgcolor=C_CV_BG, text_color=color.white, text_size=size.small)
        table.cell(cv_table, 0, 2, "RECLAIM",   bgcolor=C_CV_HDR, text_color=color.white, text_size=size.small)
        table.cell(cv_table, 1, 2, str.tostring(reclaimLevel,     format.mintick), bgcolor=C_CV_BG, text_color=color.white, text_size=size.small)
        table.cell(cv_table, 0, 3, "INVALID <", bgcolor=C_CV_HDR, text_color=color.white, text_size=size.small)
        table.cell(cv_table, 1, 3, str.tostring(invalidationLevel, format.mintick), bgcolor=C_CV_BG, text_color=color.white, text_size=size.small)
        table.cell(cv_table, 0, 4, "", bgcolor=C_CV_OFF, text_color=color.white, text_size=size.tiny)
        table.cell(cv_table, 1, 4, "", bgcolor=C_CV_OFF, text_color=color.white, text_size=size.tiny)
    else
        _no_trade = prd_state == "COMPRESSION" ? "Await expansion. No entry." : "No long setup. Stand aside."
        table.cell(cv_table, 0, 1, "", bgcolor=C_CV_OFF, text_color=color.white, text_size=size.tiny)
        table.cell(cv_table, 1, 1, _no_trade, bgcolor=C_CV_BG, text_color=color.new(#9E9E9E, 0), text_size=size.small)
        table.cell(cv_table, 0, 2, "", bgcolor=C_CV_OFF, text_color=color.white, text_size=size.tiny)
        table.cell(cv_table, 1, 2, "", bgcolor=C_CV_OFF, text_color=color.white, text_size=size.tiny)
        table.cell(cv_table, 0, 3, "", bgcolor=C_CV_OFF, text_color=color.white, text_size=size.tiny)
        table.cell(cv_table, 1, 3, "", bgcolor=C_CV_OFF, text_color=color.white, text_size=size.tiny)
        table.cell(cv_table, 0, 4, "", bgcolor=C_CV_OFF, text_color=color.white, text_size=size.tiny)
        table.cell(cv_table, 1, 4, "", bgcolor=C_CV_OFF, text_color=color.white, text_size=size.tiny)
else if barstate.islast
    table.clear(cv_table, 0, 0, 1, 4)

