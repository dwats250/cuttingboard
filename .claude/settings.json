{
  "permissions": {
    "allow": [
      "mcp__memory__create_entities",
      "Edit",
      "Write",
      "Bash(.venv/bin/pytest tests/ *)",
      "Bash(.venv/bin/pytest tests/*)",
      "Bash(ruff check *)",
      "Bash(crontab -l)",
      "Bash(systemctl is-active *)",
      "Bash(systemctl is-enabled *)",
      "Bash(dpkg -l openssh-server)",
      "Bash(ip -4 addr show)",
      "Bash(python3 -m pytest *)",
      "Bash(python -m pytest *)",
      "Bash(python3 tools/validate_prd_registry.py)",
      "Bash(python tools/validate_prd_registry.py)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(jq:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh workflow list:*)",
      "Read(**)",
      "Grep",
      "Glob",
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run watch:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push -f:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-.}\" && bash .claude/hooks/protect_files.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-.}\" && bash .claude/hooks/protect_files.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-.}\" && bash .claude/hooks/prd_eval.sh",
            "statusMessage": "Checking for PRD..."
          }
        ]
      }
    ]
  }
}
