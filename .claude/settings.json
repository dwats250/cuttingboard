{
  "permissions": {
    "allow": [
      "mcp__memory__create_entities",
      "Edit",
      "Write",
      "Bash(.venv/bin/pytest tests/ *)",
      "Bash(.venv/bin/pytest tests/*)",
      "Bash(ruff check *)",
      "Bash(crontab -l)",
      "Bash(systemctl is-active *)",
      "Bash(systemctl is-enabled *)",
      "Bash(dpkg -l openssh-server)",
      "Bash(ip -4 addr show)",
      "Bash(python3 -m pytest *)",
      "Bash(python -m pytest *)",
      "Bash(python3 -m ruff *)",
      "Bash(python -m ruff *)",
      "Bash(python3 tools/validate_prd_registry.py *)",
      "Bash(python tools/validate_prd_registry.py *)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(jq:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh workflow list:*)",
      "Read(**)",
      "Grep",
      "Glob",
      "Bash(git push:*)",
      "Bash(git commit *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git blame *)",
      "Bash(git fetch *)",
      "Bash(git merge-base *)",
      "Bash(git cat-file *)",
      "Bash(git ls-remote *)",
      "Bash(git rev-parse *)",
      "Bash(git worktree list *)",
      "Bash(git branch)",
      "Bash(git branch -a)",
      "Bash(git branch -r)",
      "Bash(git branch -v)",
      "Bash(git branch --show-current)",
      "Bash(scripts/pre_commit_sanity.sh)",
      "Bash(scripts/pre_push_check.sh)",
      "Bash(python3 scripts/check_readiness.py)",
      "Bash(python scripts/check_readiness.py)",
      "Bash(python3 scripts/resolve_run_mode.py)",
      "Bash(python scripts/resolve_run_mode.py)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks:*)",
      "Bash(gh run watch:*)",
      "Bash(gh api repos/*/pulls/*)",
      "Bash(gh api repos/*/issues/*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push -f:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh api * -X *)",
      "Bash(gh api * --method *)",
      "Bash(gh api * -f *)",
      "Bash(gh api * --raw-field *)",
      "Bash(gh api * --input *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-.}\" && bash .claude/hooks/protect_files.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-.}\" && bash .claude/hooks/protect_files.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-.}\" && bash .claude/hooks/canonical_read_guard.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-.}\" && bash .claude/hooks/prd_eval.sh",
            "statusMessage": "Checking for PRD..."
          }
        ]
      }
    ]
  }
}
