# Secrets and local config — never commit
.env
.env.*
.mcp.json
.codex
*.bak.*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenvs
.venv/
venv/
env/

# Data cache — regenerated at runtime
data/cache/*.parquet
data/backtests/*
!data/backtests/.gitkeep

# Research backtest outputs — generated locally
backtesting/output/

# CI artifacts — generated per-run, not committed
.cb_commit_msg
.claude/state/

# Auto-updated by GitNexus on every analyze run
AGENTS.md

# IDE
.vscode/
.idea/
*.swp

# Runtime and published artifacts — generated output, never commit
logs/
reports/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9].md
_site/
reports/output/
*.json
!ui/*.json
.gitnexus
.worktrees/
