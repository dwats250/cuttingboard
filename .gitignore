# Secrets and local config — never commit
.env
.env.*
.mcp.json
.codex
*.bak.*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenvs
.venv/
venv/
env/

# Data cache — regenerated at runtime
data/cache/*.parquet
data/backtests/*
!data/backtests/.gitkeep

# Research backtest outputs — generated locally
backtesting/output/

# CI artifacts — generated per-run, not committed
.cb_commit_msg
.claude/state/

# Auto-updated by GitNexus on every analyze run
AGENTS.md

# IDE
.vscode/
.idea/
*.swp

# Runtime and published artifacts
# `logs/latest_*`, `reports/*.md`, and dashboard outputs may still be force-added
# by CI when intentionally published from scheduled runs.
logs/
_site/
reports/output/
*.json
!ui/*.json
.gitnexus
logs/latest_payload.json
logs/*
!logs/latest_payload.json
!logs/latest_contract.json
!logs/market_map.json
!logs/evaluation.jsonl
